# ----------------------------------------------------------------------------
# Medical Research Agent — environment template. Copy to `.env` and fill in.
# Never commit a real .env. Secrets are read via pydantic-settings.
# ----------------------------------------------------------------------------

APP_ENV=development                 # development | production | test
LOG_LEVEL=INFO

# --- LLM providers --------------------------------------------------------
# Provider abstraction: choose default provider, override per-agent if needed.
DEFAULT_LLM_PROVIDER=groq           # openai | groq
OPENAI_API_KEY=
GROQ_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3

# --- NCBI E-utilities (PubMed) -------------------------------------------
# An email is REQUIRED by NCBI policy. An API key raises the rate limit
# from 3 to 10 requests/sec and is strongly recommended.
NCBI_TOOL=medical-research-agent
NCBI_EMAIL=you@example.com
NCBI_API_KEY=

# --- CrossRef -------------------------------------------------------------
# A mailto enters CrossRef's "polite pool" for better reliability.
CROSSREF_MAILTO=you@example.com

# --- Persistence ----------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://mra:mra@postgres:5432/mra
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=86400

# --- Observability (LangSmith, optional) ---------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=medical-research-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- API ------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_URL=http://backend:8000     # used by the Streamlit frontend
